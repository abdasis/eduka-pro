{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"title": "Display",
	"slug": "text-display",
	"blockTypes": ["core/heading", "core/paragraph"],
	"styles": {
		"typography": {
			"fontSize": "clamp(2.25rem, 2.25rem + ((1vw - 0.25rem) * 1.333), 4rem)",
			"lineHeight": "1.1",
			"fontFamily": "var:preset|font-family|fraunces"
		}
	}
}